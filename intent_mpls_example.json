            { "name": "FastEthernet0/0", "ip": "10.0.1.1", "prefix_len": 30 }
          ],
          "bgp_networks_v4": ["192.168.11.0"],
          "bgp_neighbors": [
            { "ip": "10.0.1.2", "asn": 1 }
