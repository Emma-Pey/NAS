          },
          "unused_interfaces": ["GigabitEthernet1/0", "GigabitEthernet2/0", "GigabitEthernet3/0"],
          "neighbors": [],
          "static_interfaces": [
            { "name": "FastEthernet0/0", "ip": "10.0.3.1", "prefix_len": 30 }
